{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": true,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "printWidth": 140,
  "ignorePatterns": ["dist/**", "node_modules/**"],
  "overrides": [
    {
      "files": ["**/*.json", "**/*.jsonc", "**/*.md"],
      "options": {
        "useTabs": false,
        "tabWidth": 2
      }
    }
  ]
}
