{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": true,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "arrowParens": "avoid",
  "bracketSameLine": true,
  "bracketSpacing": true,
  "printWidth": 140,
  "ignorePatterns": [
    "dist/**",
    "coverage/**",
    "*.lock",
    "pnpm-lock.yaml"
  ],
  "overrides": [
    {
      "files": [
        "**/*.json",
        "**/*.jsonc",
        "**/*.md"
      ],
      "options": {
        "useTabs": false,
        "tabWidth": 2
      }
    }
  ]
}