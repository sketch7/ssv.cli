{
  "name": "@ssv/cli",
  "version": "0.1.0",
  "private": false,
  "description": "@ssv developer tooling CLI",
  "license": "MIT",
  "author": "Stephen Lautier <stephen.lautier@outlook.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sketch7/ssv.cli.git"
  },
  "bin": {
    "ssv": "dist/cli.mjs"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.mjs",
    "gen-schema": "tsx scripts/gen-schema.ts",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "typecheck": "tsc --noEmit",
    "__CI__": "",
    "release": "npm publish"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@valibot/to-json-schema": "^1.6.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.15.9"
}
