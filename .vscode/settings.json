{
  "cSpell.words": ["Vali"],
  "json.schemas": [
    {
      "fileMatch": ["**/ssv-cli/mass-exec/**/*.json"],
      "url": "./node/toolz/mass-exec.config.schema.json"
    }
  ],
  "json.schemaDownload.enable": true,
  "json.schemaDownload.trustedDomains": {
    "https://raw.githubusercontent.com/sketch7": true
  },
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file", // tell oxfmt to format the whole file, not only the modified lines
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  }
}
